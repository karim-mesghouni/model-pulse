{
    "name": "karimms/model-pulse",
    "description": "Add collaboration, messaging, and activity tracking to any Eloquent model.",
    "license": "MIT",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Karim\\ModelPulse\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Abdelkrim Mesghouni",
            "email": "63427040+karim-mesghouni@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/container": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "spatie/eloquent-sortable": "^5.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.1"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "platform": {
            "php": "8.3"
        }
    }
}
